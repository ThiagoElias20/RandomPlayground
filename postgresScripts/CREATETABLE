-- FILTERS

SELECT * FROM aluno
WHERE name = 'Thiago';

SELECT * FROM aluno
WHERE name <> 'Thiago'; -- <> é diferente de ou !=


SELECT * FROM aluno
WHERE name LIKE '_hiago'; -- LIKE é tipo parecido (nome parecido com), _ diz q tanto faz esse caractere mes tem que acabar com hiago

SELECT * FROM aluno
WHERE name NOT LIKE '_hiago'; -- NOT LIKE é contrario do LIKE

SELECT * FROM aluno
WHERE name LIKE 'T%'; -- % ele pegaria tudo que começasse com T e tanto faz o resto
SELECT * FROM aluno
WHERE name LIKE '%o'; -- % pega todos nomes que terimna com o
SELECT * FROM aluno
WHERE name LIKE '%hiago'; --


SELECT * FROM aluno
	WHERE cpf IS NULL; -- não pode = null, é IS ou NOT IS
SELECT * FROM aluno
	WHERE cpf IS NOT NULL; -- não pode = null, é IS ou NOT IS

