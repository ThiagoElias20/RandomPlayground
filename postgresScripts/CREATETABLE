CREATE TABLE aluno (
	id SERIAL,
	name VARCHAR(255),
	cpf CHAR(11),
	observation TEXT,
	age INTEGER,
	balance NUMERIC(10,2), -- 10 vai numeros até 10 e 2 de duas casas decimais
	height real,
	active BOOLEAN,
	date_birth DATE,
	class_hour TIME,
	created_at timestamp
);

SELECT * FROM aluno;

